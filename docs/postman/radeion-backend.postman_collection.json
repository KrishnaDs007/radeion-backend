            "body": {
              "mode": "raw",
              "raw": "{\n  \"profileId\": \"{{profileId}}\",\n  \"roleName\": \"provider\",\n  \"scopeType\": \"organization\",\n  \"organizationId\": \"{{organizationId}}\",\n  \"reason\": \"Provider onboarding\"\n}"
            },
            "url": "{{baseUrl}}/roles/assignments"
          }
        },
        {
          "name": "Revoke Role Assignment",
          "request": {
            "method": "POST",
