          "name": "Create Organization",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Example Client\",\n  \"type\": \"client\",\n  \"website\": \"https://client.example.org\",\n  \"contactEmail\": \"ops@client.example.org\",\n  \"startedYear\": 2020\n}"
            },
            "url": "{{baseUrl}}/organizations"
          }
        },
        {
          "name": "Update Organization Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"disabled\",\n  \"reason\": \"Contract ended\"\n}"
            },
            "url": "{{baseUrl}}/organizations/{{organizationId}}/status"
          }
        }
      ]
    },
    {
      "name": "Users And Roles",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
