              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Role no longer applies\"\n}"
            },
            "url": "{{baseUrl}}/roles/assignments/{{roleAssignmentId}}/revoke"
          }
        }
      ]
    },
    {
