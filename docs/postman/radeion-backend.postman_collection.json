{
  "info": {
    "name": "Radeion Backend API",
    "description": "Postman collection for local Radeion backend development. Set baseUrl and supabaseAccessToken collection variables before running protected requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "supabaseAccessToken",
      "value": "replace-with-supabase-access-token"
    },
    {
      "key": "organizationId",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "profileId",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "practiceId",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "providerId",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "roleAssignmentId",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "careCoordinatorAssignmentId",
      "value": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Config Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health/config"
          }
        },
        {
          "name": "Database Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health/database"
          }
        },
        {
          "name": "Auth Methods",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/methods"
          }
        }
      ]
    },
    {
      "name": "Access Requests",
      "item": [
        {
          "name": "Create Organization Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationName\": \"Example Health ACO\",\n  \"requestedByEmail\": \"admin@example.org\",\n  \"type\": \"aco\",\n  \"website\": \"https://example.org\",\n  \"contactEmail\": \"admin@example.org\",\n  \"contactNumber\": \"+15555550100\",\n  \"address\": \"100 Example Street\",\n  \"companyBio\": \"Example healthcare organization\",\n  \"startedYear\": 2015\n}"
            },
            "url": "{{baseUrl}}/access-requests/organizations"
          }
        },
        {
          "name": "Create User Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"provider@example.org\",\n  \"organizationId\": \"{{organizationId}}\",\n  \"requestedRoles\": [\"provider\"],\n  \"requestedScope\": {\n    \"type\": \"organization\",\n    \"organizationId\": \"{{organizationId}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/access-requests/users"
          }
        },
        {
          "name": "Approve Organization Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Example Health ACO\",\n  \"type\": \"aco\",\n  \"contactEmail\": \"admin@example.org\"\n}"
            },
            "url": "{{baseUrl}}/access-requests/organizations/{{organizationRequestId}}/approve"
          }
        },
        {
          "name": "Reject User Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewNotes\": \"Organization could not be verified\"\n}"
            },
            "url": "{{baseUrl}}/access-requests/users/{{userRequestId}}/reject"
          }
        }
      ]
    },
    {
      "name": "Invites",
      "item": [
        {
          "name": "List Invites",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/invites"
          }
        },
        {
          "name": "Create Invite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"care-coordinator@example.org\",\n  \"organizationId\": \"{{organizationId}}\",\n  \"assignedRoles\": [\"careCoordinator\"],\n  \"assignedScope\": {\n    \"type\": \"organization\",\n    \"organizationId\": \"{{organizationId}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/invites"
          }
        },
        {
          "name": "Accept Invite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteToken\": \"replace-with-invite-token\",\n  \"accessToken\": \"replace-with-invitee-supabase-access-token\"\n}"
            },
            "url": "{{baseUrl}}/invites/accept"
          }
        },
        {
          "name": "Revoke Invite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/invites/{{inviteId}}/revoke"
          }
        }
      ]
    },
