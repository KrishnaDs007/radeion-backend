    {
      "name": "Databricks Reads",
      "item": [
        {
          "name": "Claims",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/claims?organizationId={{organizationId}}&limit=50"
          }
        },
        {
          "name": "Claims Sorted",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/claims?organizationId={{organizationId}}&sortBy=date&sortDirection=desc&limit=50"
          }
        },
        {
          "name": "Providers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/providers?practiceId={{practiceId}}&limit=50"
          }
        },
        {
          "name": "Patient Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supabaseAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/patient-metrics?providerId={{providerId}}&fromDate=2026-01-01&toDate=2026-01-31"
          }
        }
      ]
    }
